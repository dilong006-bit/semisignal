# EduScope 환경변수 예시 — 이 파일만 커밋한다(실제 키는 .env / Vercel env 에).
# ─────────────────────────────────────────────────────────────────────────────
# Phase 1: Vercel(Serverless) + Supabase(Auth·Postgres·RLS) 구조.
# 가드레일: 외부 API 키(ANTHROPIC)는 절대 VITE_ 접두사로 노출하지 않는다.
#           전부 /api/* 서버리스 함수(api/llm·api/news)에서만 사용한다.
# ─────────────────────────────────────────────────────────────────────────────

# ── 프론트엔드(공개 가능 · 브라우저 번들 포함) ────────────────────────
# VITE_ 접두사는 브라우저에 노출된다. anon 키는 RLS 로 보호되므로 공개 가능.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-key>

# ── 서버리스 함수 전용(비공개 · 절대 VITE_ 금지) ──────────────────────
# 로컬에서 `vercel dev` 로 /api/* 함수를 띄울 때 사용. Vercel 콘솔 env 에도 등록.
# api/llm 이 이 키로 Anthropic 을 호출한다. 브라우저는 이 키를 모른다.
ANTHROPIC_API_KEY=sk-ant-<server-only-key>
# (선택) lens 초안 생성 모델. 미지정 시 claude-opus-4-8. 모델은 서버가 결정.
ANTHROPIC_MODEL=claude-opus-4-8
# service_role 키는 RLS 를 우회한다. 서버에서만, 꼭 필요한 경우에만 사용.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# 참고: 현재 뉴스는 Google News RSS(키 불필요)를 api/news 가 프록시한다.
# 별도 NEWS_API_KEY 는 필요하지 않다.

# ─────────────────────────────────────────────────────────────────────────────
# [로컬 개발 — 서버리스 포함]
# `npm run dev`(Vite)는 정적 SPA 만 띄운다 → /api/* 는 404.
# 서버리스 함수까지 함께 띄우려면 `vercel dev` 를 사용한다(README "로컬 개발" 참고).
# `vercel dev` 는 이 .env 의 ANTHROPIC_API_KEY·ANTHROPIC_MODEL 을 함수 런타임에 주입한다.
# ─────────────────────────────────────────────────────────────────────────────
