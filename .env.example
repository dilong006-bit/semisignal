# EduScope 환경변수 예시 — 이 파일만 커밋한다(실제 키는 .env / Vercel env 에).
# ─────────────────────────────────────────────────────────────────────────────
# Phase 1: Vercel(Serverless) + Supabase(Auth·Postgres·RLS) 구조.
# 가드레일: 외부 API 키(ANTHROPIC·NEWS)는 절대 VITE_ 접두사로 노출하지 않는다.
#           전부 /api/* 서버리스 함수에서만 사용한다.
# ─────────────────────────────────────────────────────────────────────────────

# ── 프론트엔드(공개 가능) ──────────────────────────────────────────────
# VITE_ 접두사는 브라우저 번들에 포함된다. anon 키는 RLS 로 보호되므로 공개 가능.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-key>

# ── 서버리스 함수 전용(비공개 · 절대 VITE_ 금지) ──────────────────────
# 로컬에서 `vercel dev` 로 /api/* 함수를 띄울 때 사용. Vercel 콘솔 env 에도 등록.
ANTHROPIC_API_KEY=sk-ant-<server-only-key>
NEWS_API_KEY=<news-api-key>
# service_role 키는 RLS 를 우회한다. 서버에서만, 꼭 필요한 경우에만 사용.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# (선택) lens 초안 생성 모델. 미지정 시 claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────────────────────
# [Phase 0 → 1 마이그레이션 메모]
# 기존 VITE_ANTHROPIC_API_KEY 는 Phase 1 에서 폐기된다(클라이언트 노출이라 가드레일 위반).
# llmService 가 /api/lens 서버리스로 이전되면 ANTHROPIC_API_KEY(서버) 로 대체된다.
# 그 마일스톤(5번) 전까지는 로컬 .env 의 VITE_ANTHROPIC_API_KEY 로 현재 앱이 동작한다.
# ─────────────────────────────────────────────────────────────────────────────
